# ── Synera Landing Page — Environment Variables ──
#
# Copy this file to .env and fill in the values for local development.
# NEVER commit .env to version control.
#
# In production (Kubernetes), provide these values via a Secret referenced
# in infra/values.yaml under mcp.secretName.

# Port for the Express API server (default: 3000)
PORT=3000

# ── MCP Chatbot (required for the AI chat feature) ──

# Full URL of your MCP server chat endpoint
# Example: https://mcp.example.com/v1/chat/completions
MCP_SERVER_URL=

# Bearer token for MCP server authentication
MCP_AUTH_TOKEN=

# (Optional) Model identifier to pass to the MCP server
MCP_MODEL=

# (Optional) System prompt to prepend to every conversation.
# Useful for giving the chatbot a Synera-specific persona.
MCP_SYSTEM_PROMPT=Você é o assistente AI da Synera, uma consultoria brasileira especializada em Kubernetes, Platform Engineering, DevOps e modernização cloud-native. Responda em português, seja objetivo e ajude o usuário a entender como a Synera pode resolver seus desafios de plataforma.
